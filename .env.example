# в”Ђв”Ђ Local development в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Required to run `make local-db-start`, `make local-migrate`, `make process`,
# and `make test-local`.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=phototagger
DB_USER=postgres
DB_PASSWORD=localdev
DATABASE_URL=postgresql://postgres:localdev@localhost:5432/phototagger

# Anthropic vision API вЂ” required for tagging (local + Lambda).
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override. Default: claude-opus-4-6.
# ANTHROPIC_MODEL=claude-opus-4-6


# в”Ђв”Ђ Production database в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Neon serverless Postgres. Required for `make neon-migrate`, every deployed
# Lambda, and `make test-infrastructure`. Quote in shell вЂ” the URL contains
# `&` which most shells will mis-parse.

# NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&channel_binding=require


# в”Ђв”Ђ S3 buckets в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Names of the buckets managed by the deploy-*-bucket stacks. Created once via
# `make deploy-photos-bucket` etc. Referenced by the Lambda CFN templates.

# S3_BUCKET=photo-tagging-photos              # tagged photos (canonical store)
# INBOX_BUCKET=photo-tagging-inbox            # awaiting user review/promote
# UPLOAD_BUCKET=photo-tagging-uploads         # user upload staging
# THUMBNAIL_BUCKET=photo-tagging-thumbnails   # public WebP thumbnails
# FRONTEND_BUCKET=photo-tagging-frontend      # static SPA host
# DEPLOYMENT_BUCKET=photo-tagging-deployment  # Lambda zips + CFN templates


# в”Ђв”Ђ Deployment / CloudFormation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# Stack name prefix. Stacks are named ${STACK_NAME}-image, ${STACK_NAME}-inbox,
# ${STACK_NAME}-processor-v2, ${STACK_NAME}-searcher, ${STACK_NAME}-thumbnailer,
# ${STACK_NAME}-stats, plus the bucket and frontend stacks.
# STACK_NAME=photo-tagging

# Public origin used for CORS (Access-Control-Allow-Origin) on every Function
# URL. Include the scheme вЂ” e.g. http://photos.example.com (not the bare host).
# FRONTEND_DOMAIN=http://photos.example.com

# Route 53 hosted zone for the frontend custom domain (used by frontend.yaml).
# HOSTED_ZONE_ID=ZXXXXXXXXXXXXX


# в”Ђв”Ђ API key + Function URLs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# API_KEY is the shared `x-api-key` header value enforced by every Function URL
# (searcher, inbox, stats). The *_URL values are emitted as CloudFormation
# stack outputs after deploying the corresponding Lambda вЂ” copy them here
# (and into frontend/config.js вЂ” see frontend/config.example.js).

# API_KEY=...

# SEARCHER_URL=https://xxx.lambda-url.us-east-1.on.aws/
# INBOX_URL=https://xxx.lambda-url.us-east-1.on.aws/
# STATS_URL=https://xxx.lambda-url.us-east-1.on.aws/


# в”Ђв”Ђ Lambda function names (test-infrastructure only) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Read by the @infrastructure BDD scenarios when invoking deployed Lambdas
# directly via boto3 (rather than through their Function URL). Each is the
# `FunctionName` output of the corresponding CloudFormation stack.

# IMAGE_LAMBDA_NAME=photo-tagging-image-image
# INBOX_LAMBDA_NAME=photo-tagging-inbox-inbox
# THUMBNAILER_LAMBDA_NAME=photo-tagging-thumbnailer-thumbnailer
# PROCESSOR_V2_LAMBDA_NAME=photo-tagging-processor-v2-processor
# SEARCHER_LAMBDA_NAME=photo-tagging-searcher-searcher
# STATS_LAMBDA_NAME=photo-tagging-stats-stats
