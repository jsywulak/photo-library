# ── Local development ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phototagger
DB_USER=postgres
DB_PASSWORD=localdev
DATABASE_URL=postgresql://postgres:localdev@localhost:5432/phototagger

# Required for tagging (local and Lambda)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Anthropic model used for tagging (default: claude-opus-4-6)
# ANTHROPIC_MODEL=claude-opus-4-6

# ── AWS deployment ────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string (used by make neon-migrate and Lambdas)
# NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# S3 bucket where photos are stored (triggers the processor Lambda)
# S3_BUCKET=my-photos-bucket

# S3 bucket used to upload Lambda ZIPs and CloudFormation templates during deployment
# DEPLOYMENT_BUCKET=my-deployment-bucket

# CloudFormation stack name prefix (stacks will be named $STACK_NAME and $STACK_NAME-searcher)
# STACK_NAME=photo-tagger

# Custom domain for the frontend (used by CloudFormation and deploy-frontend.sh)
# FRONTEND_DOMAIN=photos.example.com
